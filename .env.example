# ─── Site ─────────────────────────────────────────────────────────────────────
# Canonical base URL used in OG tags, share links, etc.
NEXT_PUBLIC_SITE_URL=https://joseleos.com

# Your Twitter/X handle (used in OG tags and footer)
NEXT_PUBLIC_TWITTER_HANDLE=@joseleos

# ─── WordPress / CMS ──────────────────────────────────────────────────────────
NEXT_PUBLIC_WORDPRESS_API_URL=https://cms.joseLeos.com/graphql
NEXT_PUBLIC_WP_MEDIA_HOSTNAME=cms.joseLeos.com

# ─── Authentication (NextAuth v5) ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:4000

# Email address that receives owner-level access (isOwner = true)
OWNER_EMAIL=jose@joseleos.com

# Resend API key used by NextAuth to send magic-link sign-in emails
AUTH_RESEND_KEY=re_your_resend_api_key

# Optional: override the "from" address for auth emails
# AUTH_EMAIL_FROM=Jose Leos <auth@joseleos.com>

# ─── Database (Postgres) ──────────────────────────────────────────────────────
# Used by NextAuth pg adapter for session and user storage
POSTGRES_URL=postgresql://user:password@localhost:5432/joseleo

# ─── Vercel KV (Upstash Redis) ────────────────────────────────────────────────
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your-kv-token

# ─── Email — Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_AUDIENCE_ID=your-resend-audience-id
CONTACT_EMAIL_TO=jose@joseLeos.com

# ─── HubSpot CRM ──────────────────────────────────────────────────────────────
# Create a Private App in HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.write, crm.lists.write
HUBSPOT_ACCESS_TOKEN=pat-na1-your-hubspot-private-app-token
# The numeric ID of the static list to add newsletter subscribers to
HUBSPOT_NEWSLETTER_LIST_ID=123

# ─── Instagram Basic Display API ──────────────────────────────────────────────
# Long-lived access token from https://developers.facebook.com/apps
# (expires after 60 days — set up a cron to refresh it)
INSTAGRAM_ACCESS_TOKEN=your-instagram-long-lived-access-token
# Your Instagram user ID (numeric, e.g. 17841400008460056)
INSTAGRAM_USER_ID=your-instagram-user-id

# ─── Analytics ────────────────────────────────────────────────────────────────
# Your Plausible Analytics domain (optional — omit to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=joseleos.com
